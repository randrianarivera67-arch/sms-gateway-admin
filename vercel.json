{
  "version": 2,
  "outputDirectory": ".",
  "builds": [
    {"src": "*.html", "use": "@vercel/static"},
    {"src": "*.png", "use": "@vercel/static"},
    {"src": "*.json", "use": "@vercel/static"},
    {"src": "*.js", "use": "@vercel/static"}
  ],
  "routes": [
    {"src": "/sw.js", "headers": {"cache-control": "no-store, no-cache, must-revalidate"}, "dest": "/sw.js"},
    {"src": "/(.*\\.html)", "headers": {"cache-control": "no-store, no-cache, must-revalidate"}, "dest": "/$1"},
    {"src": "/", "headers": {"cache-control": "no-store, no-cache, must-revalidate"}, "dest": "/index.html"},
    {"src": "/(.*)", "dest": "/$1"}
  ]
}
